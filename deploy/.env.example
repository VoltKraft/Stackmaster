# deploy/.env.example
#
# Copy to deploy/.env and fill in real values. The real .env file is
# gitignored. Keep this file in sync when new variables are introduced.
#
# Status
#   Placeholders only. No working defaults. Every value below must be
#   replaced before first start.

# -- Master key for the credential vault ---------------------------------
# TODO: 32 random bytes, base64-encoded. Rotate with care; see docs/CREDENTIALS.md.
SM_MASTER_KEY=replace-me

# -- Database ------------------------------------------------------------
POSTGRES_PASSWORD=replace-me

# -- OIDC (external IdP — Stackmaster does NOT run one) ------------------
# Point at your existing Authentik / Keycloak / Authelia / … instance.
# See docs/AUTH.md for the IdP-side configuration.
SM_OIDC_ISSUER=
SM_OIDC_CLIENT_ID=
SM_OIDC_CLIENT_SECRET=
SM_OIDC_SCOPES=openid profile email groups
SM_OIDC_GROUPS_CLAIM=groups

# -- First-run bootstrap admin (local fallback) --------------------------
# Read once on first start and then ignored. The user MUST change the
# password on first login. Leave blank once the admin exists.
# See docs/adr/0006-auth-and-oidc.md.
SM_BOOTSTRAP_ADMIN_EMAIL=
SM_BOOTSTRAP_ADMIN_PASSWORD=

# -- Web surface ---------------------------------------------------------
# TODO: set to your public URL before going live.
# The OIDC redirect URI is derived as ${SM_PUBLIC_URL}/auth/oidc/callback.
SM_PUBLIC_URL=http://localhost:8080

# -- Logging -------------------------------------------------------------
SM_LOG_LEVEL=info
